PORT=3000

# AI_PROVIDER indica qual implementacao de AiClient deve ser usada para gerar
# a analise assistida do projeto. Atualmente apenas "mock" esta disponivel,
# atraves do MockAiClient, que gera resumo/pontos de atencao/recomendacao com
# base em regras simples, sem chamar nenhuma API externa. No futuro, essa
# variavel pode ser usada para trocar o provider registrado em
# ai-analysis.module.ts por um client real (ex: uma API de LLM), sem alterar
# o AiAnalysisService ou o ProjectsController.
AI_PROVIDER=mock
